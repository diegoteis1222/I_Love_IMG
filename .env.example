# --- Frontend (Next.js) ---
# URL pública donde corre la app
NEXT_PUBLIC_APP_NAME="I Love IMG"

# URL interna del microservicio de IA (entre contenedores Docker)
AI_SERVICE_URL=http://ai-service:8001

# Límites de subida
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_REQUEST=20

# --- Servicio IA (Python) ---
# Modelo de rembg a usar (u2net | birefnet-general | isnet-general-use)
REMBG_MODEL=birefnet-general

# Lado máximo al que se procesa el inpainting (quitar marca de agua).
# Más alto = mejor detalle pero más lento en CPU.
INPAINT_MAX_SIDE=1600
